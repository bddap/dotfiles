#!/usr/bin/env bash
# run-untrusted — execute a command inside a locked-down bubblewrap sandbox.
#
# Use this for ANY untrusted third-party code: building/testing an OSS project,
# running a downloaded script, executing a build.rs / npm postinstall, etc. The
# bot runs as `bot` with passwordless sudo, so untrusted code run directly = root.
# Inside this sandbox the same code:
#   • cannot gain privileges (user namespace + no-new-privs → `sudo` is useless)
#   • cannot see $HOME, so ~/.secrets, ~/.ssh, tokens are invisible
#   • sees a read-only system (/nix, /etc essentials) and a private /tmp
#   • can write ONLY the work dir (cwd, or $SANDBOX_DIR)
#   • has network by default; pass -n as the first arg to cut it
#
# Usage:
#   run-untrusted [-n] CMD [ARGS...]
#   SANDBOX_DIR=/path/to/project run-untrusted cargo test
set -euo pipefail

# If bwrap isn't on PATH yet (pre-rebuild), re-exec ourselves inside nix-shell.
if ! command -v bwrap >/dev/null 2>&1; then
  exec nix-shell -p bubblewrap --run "$(printf '%q ' "$0" "$@")"
fi

net=(--share-net)
if [ "${1:-}" = "-n" ]; then net=(--unshare-net); shift; fi
[ "$#" -ge 1 ] || { echo "usage: run-untrusted [-n] CMD [ARGS...]" >&2; exit 64; }

work="$(realpath -m "${SANDBOX_DIR:-$PWD}")"
case "$work" in
  "$HOME"|"$HOME"/|"$HOME"/.secrets*|"$HOME"/.ssh*|/|/etc*|/nix*|/root*|/boot*)
    echo "run-untrusted: refusing unsafe work dir: $work" >&2; exit 2;;
esac
[ -d "$work" ] || { echo "run-untrusted: work dir does not exist: $work" >&2; exit 2; }

exec bwrap \
  --unshare-all "${net[@]}" \
  --die-with-parent \
  --new-session \
  --ro-bind /nix /nix \
  --ro-bind /run/current-system /run/current-system \
  --ro-bind-try /etc/resolv.conf /etc/resolv.conf \
  --ro-bind-try /etc/ssl /etc/ssl \
  --ro-bind-try /etc/static /etc/static \
  --ro-bind-try /etc/nsswitch.conf /etc/nsswitch.conf \
  --ro-bind-try /etc/hosts /etc/hosts \
  --ro-bind-try /bin /bin \
  --ro-bind-try /usr /usr \
  --proc /proc \
  --dev /dev \
  --tmpfs /tmp \
  --bind "$work" "$work" \
  --chdir "$work" \
  --setenv HOME /tmp \
  --setenv PATH /run/current-system/sw/bin:/bin:/usr/bin \
  --setenv SANDBOX 1 \
  -- "$@"
